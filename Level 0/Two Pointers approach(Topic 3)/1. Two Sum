class Solution {
public:
    vector<int> twoSum(vector<int>& nums, int target) {
        unordered_map<int,int> mp;
        int size = nums.size();

        for(int i=0; i<size;i++){
            int complement = target - nums[i];
            if(mp.count(complement)){  // agr element exist krta to 1 otherwise 0. 
                return {mp[complement],i};
            }

            mp[nums[i]]= i;
        }

        return {-1,-1};
    }
};

// Time complexity will be O(n) and space will also be O(n) bcz we are using hashmaps for faster lookup.
