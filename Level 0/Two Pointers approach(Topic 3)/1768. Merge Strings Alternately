class Solution {
public:
    string mergeAlternately(string word1, string word2) {
        int i=0,j=0;
        int n1=word1.size(),n2=word2.size();
        string result;

        while(i<n1 && j<n2){  // n1,n2 are sizes of word1 and word2 respectively
            result.push_back(word1[i]);
            i++;

            result.push_back(word2[j]);
            j++;
        }

        // either word1 will be fully exhausted or word2 but dont know so 
        while(i<n1){
            result.push_back(word1[i]);
            i++;
        }

        while(j<n2){
            result.push_back(word2[j]);
            j++;
        }

        return result;
    }
};
