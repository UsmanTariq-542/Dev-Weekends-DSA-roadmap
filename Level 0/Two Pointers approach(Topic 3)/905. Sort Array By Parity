class Solution {
public:
    vector<int> sortArrayByParity(vector<int>& nums) {
        int size = nums.size(),j=0;
        for(int i=0; i<size; i++){
            if(nums[i]%2==0){  // even mila i pointer ko
                swap(nums[i],nums[j]);
                j++;
            }
        }

        return nums;
    }
};

// Time complexity is O(n) and space is O(1)
