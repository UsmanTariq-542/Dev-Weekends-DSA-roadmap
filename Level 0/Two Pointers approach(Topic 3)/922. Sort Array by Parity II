class Solution {
public:
    vector<int> sortArrayByParityII(vector<int>& nums) {
        int size = nums.size();

        int j=1;  // j index for odd 

        for(int i=0; i<size; i+=2){ // even indices p scan kr rha ha
            if(nums[i]%2==1){  // koi odd no mil gya 
                while(nums[j]%2==1) j+=2; // jb tk j index p odd ata rha, keep incrementing.
                swap(nums[j],nums[i]);
            }
        }

        return nums;
    }
};
