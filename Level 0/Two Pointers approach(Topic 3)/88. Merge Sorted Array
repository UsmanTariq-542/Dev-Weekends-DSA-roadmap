class Solution {
public:
    void merge(vector<int>& nums1, int m, vector<int>& nums2, int n) {
        int i=0,j=0,k=0;
        vector<int> temp1 = nums1;
        nums1={};

        while(i<m && j<n){
            if(temp1[i]<nums2[j]){
                nums1.push_back(temp1[i]);
                i++;
            }
            else{
                nums1.push_back(nums2[j]);
                j++;
            }
        }

        while(i<m){
            nums1.push_back(temp1[i]);
            i++;
        }

        while(j<n){
            nums1.push_back(nums2[j]);
            j++;
        }

    }
};

Time complexity is O(2n) ~ O(n) and space is O(n) bcz we took temp1 here.
