// Approach 2:
class Solution {
public:
    void rotate(vector<int>& nums, int k) {
        int size=nums.size();
        k= k % size;

        reverse(begin(nums),end(nums)); // reverse whole nums array

        reverse(begin(nums),begin(nums)+k);

        reverse(begin(nums)+k,end(nums));
    }
};

