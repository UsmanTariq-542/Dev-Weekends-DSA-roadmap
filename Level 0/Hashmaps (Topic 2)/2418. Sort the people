class Solution {
public:
    vector<string> sortPeople(vector<string>& names, vector<int>& heights) {
        vector<string> result;
        map<int,string> mp;
        int size = names.size();

        for(int i=0; i<size; i++){
            mp[heights[i]]=names[i];
        }

        for(auto it = mp.rbegin(); it!=mp.rend(); it++){
            result.push_back(it->second);
        }

        return result;
    }
};
