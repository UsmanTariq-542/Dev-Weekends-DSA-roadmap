class Solution {
public:
    int majorityElement(vector<int>& nums) {
        int size = nums.size();
        unordered_map<int,int> mp;

        for(int& n:nums){
            mp[n]++;
        }

        for(auto& it:mp){
            if(it.second>size/2){
                return it.first;
            }
        }

        return -1;
    }
};
