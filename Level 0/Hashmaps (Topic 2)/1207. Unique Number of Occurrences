Approach 02: vector of int of size 2001 and then sorting and checking duplicate 
class Solution {
public:
    bool uniqueOccurrences(vector<int>& arr) {
        vector<int> nums(2001,0);  // bcz arr values range is -1000 to 1000 

        int size = arr.size();
        for(int i=0; i<size;i++){
            int num = arr[i];
            nums[num+1000]++;
        }

        sort(begin(nums),end(nums));

        for(int i=1;i<2001;i++){
            if(nums[i]!=0 && nums[i]==nums[i-1]){
                return false;
            }
        }
        return true;
    }
};
