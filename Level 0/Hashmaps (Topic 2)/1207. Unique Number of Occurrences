class Solution {
public:
    bool uniqueOccurrences(vector<int>& arr) {
        unordered_map<int,int> mp;
        unordered_set<int> st;
        for(int& n:arr){
            mp[n]++;
        }

        for(auto& it:mp){
            int freq = it.second;
            if(st.find(freq)!=st.end()){
                return false;
            }
            st.insert(freq);
        }

        return true;
    }
};

