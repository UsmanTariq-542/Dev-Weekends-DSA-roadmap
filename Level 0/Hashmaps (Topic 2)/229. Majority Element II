class Solution {
public:
    vector<int> majorityElement(vector<int>& nums) {
        int maj1=NULL,maj2=NULL;
        int count1=0,count2=0;

        int size = nums.size();
        for(int i=0;i<size;i++){
            if(maj1==nums[i]){
                count1++;
            }
            else if(maj2==nums[i]){
                count2++;
            }
            else if(count1==0){
                maj1=nums[i];
                count1=1;
            }
            else if(count2==0){
                maj2=nums[i];
                count2=1;
            }
            else{
                count1--;
                count2--;
            }
        }

        // verify krna 
        int freq1=0,freq2=0;
        for(int& n:nums){
            if(n==maj1) freq1++;
            else if(n==maj2) freq2++;
        }

        vector<int> result;
        if(freq1> floor(size/3)){
            result.push_back(maj1);
        }

        if(freq2> floor(size/3)){
            result.push_back(maj2);
        }

        return result;
    }
};
