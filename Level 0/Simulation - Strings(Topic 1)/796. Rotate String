// Approach # 02: string concatenation
class Solution {
public:
    bool rotateString(string s, string goal) {
        int size_s = s.size(),size_g = goal.size();
        if(size_s!= size_g) return false;

        string concatenated=s+s;
        if((concatenated).find(goal) != string::npos){
            return true;  //can also write <size_s bcz find returns an index of start pos of goal.
        }

        return false;
    }
};

// concatenated will contain all rotations of original string s, thats why...
