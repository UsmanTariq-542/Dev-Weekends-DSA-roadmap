class Solution {
public:
    bool isPalindrome(string s) {
        int size=s.size();
        int i=0,j=size-1; 

        while(i<j){
            if(s[i]>='A' && s[i]<='Z'){  // to convert to lower case.
                s[i]+=32;
            }

            else if((s[i]<'a' || s[i]>'z') && (s[i]<'0' || s[i] >'9')){
                i++;
                continue;
            }

            if(s[j]>='A' && s[j]<='Z'){  // to convert to lower case.
                s[j]+=32;
            }

            else if((s[j]<'a' || s[j]>'z') && (s[j]<'0' || s[j] >'9')){  // ignoring non alpha chars
                j--;
                continue;
            }

            if(s[i]!=s[j]) return false;
            i++;
            j--;
        }

        return true;
    }
};

