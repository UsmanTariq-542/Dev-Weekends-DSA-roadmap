class Solution {
public:
    int numJewelsInStones(string jewels, string stones) {
        int result=0;
        int size_s=stones.size();
        for(int i=0;i<size_s;i++){
            char target=stones[i];
            for(char &ch:jewels){
                if(ch==target){
                    result++;
                    break;
                }
            }
        }

        return result;
        
    }
};
