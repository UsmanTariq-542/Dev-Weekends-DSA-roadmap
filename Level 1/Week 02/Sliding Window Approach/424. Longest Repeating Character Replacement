class Solution {
public:
    int characterReplacement(string s, int k) {
        int size = s.size();
        int i=0,j=0,maxf=0,maxlength=0;
        vector<int> hash(26,0);

        while(j<size){
            char ch=s[j];
            hash[ch-'A']++;
            maxf=max(maxf,hash[ch-'A']);

            int currlength=j-i+1;
            if(currlength-maxf<=k){
                maxlength=max(maxlength,currlength);
            }
            else{
                hash[s[i]-'A']--;
                i++;
            }


            j++;
        }

        return maxlength;
    }
};