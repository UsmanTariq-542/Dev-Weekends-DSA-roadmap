class Solution {
public:
    int findDuplicate(vector<int>& nums) {
        int s=nums[0];
        int f = nums[0];

        s=nums[s];
        f=nums[nums[f]];

        while(s!=f){  //as arr size is n+1 and only 1 to n numbers valid so atleast one nmbr twice.
            s=nums[s];
            f=nums[nums[f]];
        }

        s = nums[0];
        while(s!=f){
            s=nums[s];  // 2(L1+L2) = L1+L2+nk
            f=nums[f];  // L1=nk-L2
        }

        return s;  // or fast bcz they are equal when loop breaks.
    }
};
