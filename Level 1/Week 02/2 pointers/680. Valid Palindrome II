class Solution {
public:
    bool solve(string& s,int i,int j){
        while(i<=j){
            if(s[i]!=s[j]){
                return false;
            }
            i++;
            j--;
        }

        return true;
    }


    bool validPalindrome(string s) {
        int size = s.size();
        int i=0,j=size-1;

        while(i<j){
            if(s[i]==s[j]){
                i++;
                j--;
            }
            else{
                bool left = solve(s,i+1,j);
                bool right = solve(s,i,j-1);
                return (left|| right);
            }
        }

        return true;
    }
};
