class Solution {
public:
    int removeDuplicates(vector<int>& nums) {
        int i=0,j=1,size=nums.size();
        
        while(j<size){
            if(nums[i]!=nums[j]){
                i++;
                swap(nums[i],nums[j]);
            }
            j++;
        }

        return i+1;

    }
};
