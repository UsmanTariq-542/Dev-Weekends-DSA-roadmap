// Approach 2 using two pointers and sorting the array.
class Solution {
public:
    int countPairs(vector<int>& nums, int target) {
        int size = nums.size(),count=0;
        sort(begin(nums),end(nums));

        int i = 0, j = size-1;
        while(i<j){
            int sum = nums[i]+nums[j];
            if(sum>=target){
                j--;
            }
            else{
                count+=(j-i);
                i++;
            }
        }

        return count;
    }
};
