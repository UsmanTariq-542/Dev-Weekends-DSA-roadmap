// Brute force approach of nested loops
class Solution {
public:
    int countPairs(vector<int>& nums, int target) {
        int size = nums.size(),count=0;
        for(int i=0;i<size;i++){
            for(int j=i+1;j<size;j++){
                int sum = nums[i]+nums[j];
                if(sum<target){
                    count++;
                }
            }
        }

        return count;
    }
};

