class Solution {
public:
    bool isAnagram(string s, string t) {
        int arr[26];
        int n1=s.size(),n2=t.size();
        if(n1!=n2) return false;

        for(char &ch:s){
            arr[ch-'a']++;
        } 

        for(char &ch:t){
            arr[ch-'a']--;
            if(arr[ch-'a']<0) return false;
        }

        for(int i=0;i<26;i++){
            if(arr[i]!=0) return false;
        }

        return true;
    }
};
