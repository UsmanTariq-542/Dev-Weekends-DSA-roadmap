/*
without using extra space like making result and first storing left product and a single variable like RP and updating each every time.
*/
class Solution {
public:
    vector<int> productExceptSelf(vector<int>& nums) {
        int size=nums.size(),RP=1;
        vector<int> left(size); // here using left as a result 
        left[0]=1;
        for(int i=1;i<size;i++){
            left[i]=left[i-1]*nums[i-1];
        }

        for(int i=size-1;i>=0;i--){
            left[i]=left[i]*RP;
            RP*=nums[i];
        }


        return left;
    }
};
