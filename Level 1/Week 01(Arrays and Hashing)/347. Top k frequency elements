// Approach # 01: 
class Solution {
public:
    vector<int> topKFrequent(vector<int>& nums, int k) {
        typedef pair<int,int> P;

        unordered_map<int,int> mp;
        for(int& n:nums){
            mp[n]++;
        }

        // by default is maxheap, and declared as priority_queue<int> 
        priority_queue<P,vector<P>,greater<P>> pq;  // minheap-> smallest element on top

        for(auto& it:mp){
            int val = it.first;
            int freq = it.second;

            pq.push({freq,val});

            if(pq.size()>k){
                pq.pop(); // smallest frequency element will be popped out.
            }
        }

        // now making a result vector
        vector<int> result;

        while(!pq.empty()){
            result.push_back(pq.top().second);
            pq.pop();
        }

        return result;
    }
};


