// Approach 01: using nested loop and time complexity will be O(n**2) and space is constant.
class Solution {
public:
    vector<int> twoSum(vector<int>& nums, int target) {
        int a=-1,b=-1;
        int size=nums.size();
        for(int i=0;i<size;i++){
            bool flag=false;
            for(int j=i+1;j<size;j++){
                if(nums[i]+nums[j]==target){
                    a=i,b=j;
                    flag=true;
                    break;
                }
            }
            if(flag){
                break;
            }
        }

        return {a,b};
    }
};

