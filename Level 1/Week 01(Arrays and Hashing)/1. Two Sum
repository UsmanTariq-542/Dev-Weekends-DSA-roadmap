// Approach 02: using unordered_map and time and space complexity will be O(n) each.
class Solution {
public:
    vector<int> twoSum(vector<int>& nums, int target) {
        unordered_map<int,int> mp;
        int size = nums.size();

        for(int i=0;i<size;i++){
            int complement = target-nums[i];
            if(mp.find(complement)!=mp.end()){   // complement seen before already
                return {mp[complement],i};
            }
            else{
                mp[nums[i]]=i;
            }
        }

        return {};//since each input would have exactly one solution, so control never reached here
    }
};
