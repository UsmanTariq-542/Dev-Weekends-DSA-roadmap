class Solution {
public:
    vector<vector<string>> groupAnagrams(vector<string>& strs) {
        int size = strs.size();
        unordered_map<string,vector<string>> mp;

        vector<vector<string>> result;

        for(int i=0;i<size;i++){
            string temp = strs[i];
            sort(begin(temp),end(temp));

            mp[temp].push_back(strs[i]);
        }

        for(auto& it:mp){
            result.push_back(it.second);
        }

        return result;
    }
};

================================================================================

Approach # 2:
    As our problem has given that only smaller alphabets are allowed so we can take an
    array of 26 size and solve it in O(n*k) and using a function to generate newword
    automatically without sorting.
    
    */

    string generate(string word){
        int arr[26]={0};
        for(char& ch : word){   // each word individual character is passed by reference.
            arr[ch-'a']++;   // suppose ch is 'd' , then 100-97=3 so index: 3, incr by 1
        }
        
        string newword="";
        for(int i=0;i<26;i++){
            int freq=arr[i];
            if(freq>0){
                newword+=string(freq,i+'a');
            }
        }

        return newword;
    }

    vector<vector<string>> groupAnagrams(vector<string>& strs) {
        int size=strs.size();

        unordered_map<string,vector<string>> mp;   // for storing key, value pairs in it
        vector<vector<string>> result;    // for returning final answer

        for(int i=0;i<size;i++){
            string word=strs[i];
            string new_word=generate(word);
            mp[new_word].push_back(word);
        }

        for(auto it: mp){   // means automatic iterate in mp
            result.push_back(it.second);// it.second is a vector of strings so whole 
            // vector is pushed back in result.
        }

        return result;

    }
