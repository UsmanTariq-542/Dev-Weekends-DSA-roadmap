class Solution {
public:
    Node* copyRandomList(Node* head) {
        if(head==NULL) return head;

        unordered_map<Node*, Node*> mp;

        Node* curr = head;
        Node* prev=NULL, *newHead=NULL;

        while(curr){
            Node* temp = new Node(curr->val);

            // maintaining a map for nodes of older and new lists.
            mp[curr]=temp;

            if(newHead==NULL){  // first node insertion
                newHead=temp;
                prev=newHead;
            }

            else{
                prev->next=temp;
                prev=temp;
            }

            curr=curr->next;
        }

        // now filling random pointers in deep copy linkedlist
        curr=head;
        Node* newcurr=newHead;
        while(curr){
            if(curr->random==NULL){
                newcurr->random=NULL;
            }
            else{
                newcurr->random = mp[curr->random];
            }

            curr = curr->next;
            newcurr=newcurr->next;
        }

        return newHead;
    }
};
