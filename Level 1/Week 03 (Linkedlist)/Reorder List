/**
 * Definition for singly-linked list.
 * struct ListNode {
 *     int val;
 *     ListNode *next;
 *     ListNode() : val(0), next(nullptr) {}
 *     ListNode(int x) : val(x), next(nullptr) {}
 *     ListNode(int x, ListNode *next) : val(x), next(next) {}
 * };
 */
class Solution {
public:
    ListNode* reverseLL_iteratively(ListNode* head){
        if(head==NULL || head->next==NULL) return head; // basecase

        ListNode* prev=NULL,*curr=head;

        while(curr){
            ListNode* next = curr->next;
            curr->next=prev;
            prev=curr;
            curr=next;
        }

        return prev;
    }

    ListNode* reverseLL_recursively(ListNode* head){
        if(head==NULL || head->next==NULL) return head; // base case

        ListNode* last = reverseLL_recursively(head->next);
        head->next->next = head;
        head->next = NULL;

        return last;
    }

    void reorderList(ListNode* head) {
        if(head==NULL || head->next==NULL || head->next->next==NULL) return;

        ListNode* slow=head,*fast=head;

        while(fast&& fast->next){
            slow=slow->next;
            fast=fast->next->next;
        }

        ListNode* rev = reverseLL_iteratively(slow);
        ListNode* curr = head;

        while(rev->next){
            ListNode* tempcurr = curr->next;
            curr->next= rev;

            ListNode* temprev=rev->next;
            rev->next=tempcurr;

            rev=temprev;
            curr=tempcurr;
        }
    }
};